# Environment configuration for Blackwell RTX PRO 2000 (sm_120)
# This setup uses Docker Model Runner for teacher (llama.cpp may support Blackwell)
# and CPU-only mode for training (PyTorch doesn't support sm_120 yet)

# Docker runtime: empty string disables GPU runtime for CPU-only mode
DOCKER_RUNTIME=

# Teacher Backend: Use Docker Model Runner (built into Docker Desktop)
TEACHER_BACKEND=docker_model_runner

# Docker Model Runner URL (accessible from container)
DOCKER_MODEL_RUNNER_URL=http://model-runner.docker.internal/engines/v1

# Teacher model to use with Docker Model Runner
# Pull with: docker model pull ai/qwen2.5:7B-Q4_K_M
TEACHER_MODEL=ai/qwen2.5:7B-Q4_K_M

# Device: Force CPU for training (PyTorch doesn't support sm_120 yet)
DEVICE=cpu

# Disable GPU visibility to prevent PyTorch from attempting to use unsupported GPU
CUDA_VISIBLE_DEVICES=""

# Reduce sequence length for CPU training (faster)
max_seq_len=1024

# Reduce batch size for CPU training
batch_size=2

# Enable gradient checkpointing to save memory
gradient_checkpointing=true

# Use smaller model for CPU training (Qwen2.5-0.5B has hidden_size=896)
base_model_name=Qwen/Qwen2.5-0.5B-Instruct

# MoE configuration (match base model hidden_size)
num_experts=4
top_k=2
hidden_size=896
intermediate_size=1792

# Training epochs (keep low for testing)
epochs=1

# Learning rate
learning_rate=5e-5

# Distillation settings
distill_n_samples=100  # Small dataset for testing
distill_temperature=0.7
distill_max_tokens=512
