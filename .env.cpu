# Environment configuration for CPU-only mode
# Use this if you don't have a GPU or for testing

# Docker runtime: empty string disables GPU runtime
DOCKER_RUNTIME=

# Teacher Backend: Use Docker Model Runner or Ollama
TEACHER_BACKEND=docker_model_runner
TEACHER_MODEL=ai/qwen2.5:7B-Q4_K_M
DOCKER_MODEL_RUNNER_URL=http://model-runner.docker.internal/engines/v1

# Device: CPU mode
DEVICE=cpu

# Disable GPU visibility
CUDA_VISIBLE_DEVICES=""

# Use smaller model for CPU
base_model_name=Qwen/Qwen2.5-0.5B-Instruct

# Reduce sequence length for CPU training (faster)
max_seq_len=512

# Reduce batch size for CPU training
batch_size=1

# Disable gradient checkpointing for CPU mode (very slow on CPU)
gradient_checkpointing=false

# MoE configuration (match Qwen2.5-0.5B hidden_size)
num_experts=4
top_k=2
hidden_size=896
intermediate_size=1792

# Training (keep low for CPU)
epochs=1
learning_rate=5e-5

# Distillation (small dataset for testing)
distill_n_samples=100
distill_temperature=0.7
distill_max_tokens=512
