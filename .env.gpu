# Environment configuration for RTX 40-series (12GB+ VRAM) - Full GPU Mode
# This is the default configuration - no .env file needed for most users

# Teacher Backend: Use Ollama (default) or Docker Model Runner
TEACHER_BACKEND=ollama
TEACHER_MODEL=qwen3.5:27b

# Device: GPU mode
DEVICE=cuda

# Base model (Qwen3-4B fits in 12GB with 4-bit quantization)
base_model_name=Qwen/Qwen3-4B-Instruct

# Sequence length
max_seq_len=4096

# Batch size
batch_size=1

# Gradient checkpointing
gradient_checkpointing=true

# MoE configuration (match Qwen3-4B hidden_size)
num_experts=4
top_k=2
hidden_size=2560
intermediate_size=5120

# Training
epochs=3
learning_rate=2e-4

# Distillation
distill_n_samples=2000
distill_temperature=0.7
distill_max_tokens=2048
